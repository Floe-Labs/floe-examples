# ── Required for both demos ───────────────────────────────────────────────────
# Wallet private key (0x...). The agent's Floe identity. Must be funded for
# on-chain credit delegation provisioning.
PRIVATE_KEY=0x_your_private_key_here

# Floe credit key (floe_...). Authenticates the facilitator + metered LLM proxy
# and is what gets debited. The SDK does not read this env var itself — the demos
# forward it to X402Config(facilitator_api_key=...).
FLOE_FACILITATOR_API_KEY=floe_your_key_here

# Base URL of the Floe credit API. The metered LLM proxy lives at <base>/v1/llm.
FLOE_API_BASE_URL=https://credit-api.floelabs.xyz

# Base chain id (Base mainnet).
CHAIN_ID=8453

# ── loop_kill.py (metered-LLM proxy demo) ─────────────────────────────────────
# Upstream provider key, passed through to the Floe proxy via X-Floe-Provider-Key.
# Floe never stores it.
OPENAI_API_KEY=sk-your-key-here
# Optional: override the model routed through the proxy.
FLOE_LLM_MODEL=openai/gpt-4o

# ── procurement_crew.py (allowlist + overspend demo) ──────────────────────────
# Real x402-gated endpoints. Host A and Host B are allowlisted ($2 / $1 caps);
# the off-allowlist URL must be on a host that is NOT in the allowlist.
FLOE_DEMO_HOST_A_URL=https://allowlisted-host-a.example/paid-endpoint
FLOE_DEMO_HOST_B_URL=https://allowlisted-host-b.example/paid-endpoint
FLOE_DEMO_OFFLIST_URL=https://not-allowlisted-host.example/paid-endpoint
# All three agents share the single PRIVATE_KEY above — budget_enabled_agent
# provisions a distinct managed agent per role, so no per-role keys are needed.
