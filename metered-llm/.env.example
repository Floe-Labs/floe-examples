# Your Floe agent key (floe_<hex>) — get one at https://dev-dashboard.floelabs.xyz
FLOE_API_KEY=floe_your_agent_key

# Your upstream OpenAI or Anthropic key — passed through to the provider, never stored by Floe.
PROVIDER_API_KEY=sk-your-openai-or-anthropic-key

# Any priced model. Default: gpt-5.5. Try claude-opus-4-8, claude-sonnet-4-6, gpt-5.4-mini, …
# FLOE_MODEL=gpt-5.5
