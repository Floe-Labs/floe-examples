# Vapi private key — get it at https://dashboard.vapi.ai
# Server-side only (used by setup.ts + call.ts). Never put this in the browser.
VAPI_API_KEY=

# Vapi PUBLIC key — also from the Vapi dashboard.
# Only needed for the OPTIONAL web widget (safe in client HTML, served via GET /config).
# Not needed for the outbound phone call.
VAPI_PUBLIC_KEY=

# Assistant id — printed by setup.ts after it creates the assistant.
VAPI_ASSISTANT_ID=

# The Vapi phone number to call FROM (its id, not the number itself).
# Find it in the Vapi dashboard under Phone Numbers. If left blank, call.ts uses your first number.
VAPI_PHONE_NUMBER_ID=

# The user's cell to call, E.164 format (e.g. +14155551234). The agent calls this number.
TARGET_PHONE_NUMBER=

# Floe — get your key at https://dev-dashboard.floelabs.xyz
FLOE_API_KEY=

# Session spend cap in USDC base units (6 decimals): 30000 = $0.03 (~6 Exa searches).
# Kept low so the budget cap is reachable in a short demo call.
# setup.ts sets this cap on Floe; server.ts mirrors it for the budget line.
FLOE_SPEND_LIMIT_RAW=30000

# Webhook secret — set in Vapi dashboard under server URL credentials
# Prevents unauthorized callers from triggering paid API calls
VAPI_SERVER_SECRET=

# Your server's public URL (use ngrok for local dev)
# Vapi needs to reach this URL to send tool-call webhooks
SERVER_URL=https://your-ngrok-url.ngrok-free.app

# Server port
PORT=3000

# Uncomment to log full Vapi webhook payloads (loud — one block per request)
# DEBUG=1
